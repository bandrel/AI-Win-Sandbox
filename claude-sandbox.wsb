<Configuration>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>.</HostFolder>
      <SandboxFolder>C:\setup</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <MappedFolder>
      <HostFolder>%USERPROFILE%\.claude</HostFolder>
      <SandboxFolder>C:\ClaudeHostConfig</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>cmd.exe /c start powershell.exe -NoExit -ExecutionPolicy Bypass -File C:\setup\setup.ps1</Command>
  </LogonCommand>
</Configuration>
